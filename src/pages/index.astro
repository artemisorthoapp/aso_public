---
// Landing page — recreated from the v4 Claude Design handoff
// ("Artemis Ortho Website v4.dc.html" + design_handoff README, Jun 2026).
// Value/savings-led long-scroll: navy hero with an animated savings counter,
// a stats band, the interactive Value Calculator centerpiece, "what we
// replace", an auto-scrolling integrations marquee, the five-verb product
// grid on real screenshots, a testimonial, and the demo/pricing lead form.
//
// Self-contained single page with its own fixed nav + footer (does NOT use
// Base/Nav/Footer). The Claude-Design runtime (<x-dc>, support.js, DCLogic)
// is stripped: the savings counter, calculator, marquee, scroll-reveal and
// form submit run as plain inline scripts. The form posts to the real
// /api/trial Pages Function in the background (FormData) and shows an inline
// confirmation — by design the visitor is NOT redirected into the app
// (leads are contacted by the Artemis team). All motion is gated behind
// prefers-reduced-motion.
const title = "Artemis Ortho App — your whole practice, on one platform";
const description =
  "Artemis replaces the 15+ disconnected tools orthodontic practices juggle — analytics, communication, marketing, financials, insurance and more — with one calm system that runs itself. Request a demo.";
const canonical = new URL("/", Astro.site).href;

// ----- Value calculator: 11 tool categories a practice pays for today -----
// Monthly costs are representative benchmarks (handoff cost model). All-checked
// total = $5,800/mo ≈ $69,600/yr, inside the researched $49,800–99,000 range.
const tools = [
  { k: "analytics", name: "Analytics & BI dashboards", eg: "Gaidge, Practice analytics", cost: 500 },
  { k: "comm", name: "Patient communication / texting", eg: "Weave, Podium", cost: 600 },
  { k: "social", name: "Social media management", eg: "Hootsuite + agency", cost: 800 },
  { k: "seo", name: "SEO & local search", eg: "Marketing agency", cost: 1000 },
  { k: "reviews", name: "Reviews management", eg: "Birdeye", cost: 400 },
  { k: "money", name: "Financials & bookkeeping automation", eg: "QB add-ons, bookkeeper", cost: 700 },
  { k: "ins", name: "Insurance verification", eg: "Verification service", cost: 500 },
  { k: "inv", name: "Inventory management", eg: "Inventory software", cost: 250 },
  { k: "hr", name: "HR, training & payroll", eg: "LMS + payroll add-ons", cost: 350 },
  { k: "ai", name: "AI assistant", eg: "Standalone AI tools", cost: 300 },
  { k: "hipaa", name: "HIPAA compliance", eg: "Compliancy Group", cost: 400 },
];

// ----- What we replace: 11-category grid (old vendor → Artemis) -----
const categories = [
  { icon: "◷", title: "Analytics & BI", replaces: "Gaidge / dashboards" },
  { icon: "❝", title: "Patient communication", replaces: "Weave / Podium" },
  { icon: "◎", title: "Social media", replaces: "Hootsuite + agency" },
  { icon: "⌕", title: "SEO & local search", replaces: "SEO agency" },
  { icon: "★", title: "Reviews", replaces: "Birdeye" },
  { icon: "$", title: "Financials & bookkeeping", replaces: "QB add-ons / bookkeeper" },
  { icon: "⛉", title: "Insurance verification", replaces: "Verification service" },
  { icon: "▦", title: "Inventory (QR scanning)", replaces: "Inventory software" },
  { icon: "⚇", title: "HR, training & payroll", replaces: "LMS + payroll tools" },
  { icon: "✦", title: "AI assistant", replaces: "Standalone AI tools" },
  { icon: "⛨", title: "HIPAA compliance", replaces: "Compliancy Group" },
];

const integrations = [
  "Cloud 9", "QuickBooks", "Meta", "Instagram", "TikTok", "YouTube",
  "Google", "Twilio", "Stedi", "Stripe", "Canva", "HeyGen",
  "Paychex", "Birdeye", "Google Business",
];

// ----- Five-verb product cards (Today is a featured wide card) -----
const verbs = [
  {
    n: "02", verb: "People", img: "/gallery/02-people-funnel.jpg",
    title: "Every patient, end to end.",
    body: "Treatment funnel, patient detail, scheduling, communication, insurance, and aligner cases — in one record.",
  },
  {
    n: "03", verb: "Growth", img: "/gallery/08-growth.jpg",
    title: "Marketing that runs itself.",
    body: "A social calendar that publishes directly to your own TikTok, Instagram, and YouTube accounts, plus SEO, leads, reviews, blog generation, and sponsorships — all in one place.",
  },
  {
    n: "04", verb: "Money", img: "/gallery/16-money.jpg",
    title: "The numbers, reconciled nightly.",
    body: "QuickBooks sync, automated close reports, AR aging, and production vs. targets — without the spreadsheet.",
  },
  {
    n: "05", verb: "Operations", img: "/gallery/19-operations.jpg",
    title: "The back office, handled.",
    body: "Inventory with QR scanning, employee reviews, training, payroll, and practice manuals — organized.",
  },
];

const fmt = (n: number) => "$" + Math.round(n).toLocaleString("en-US");
const monthlyTotal = tools.reduce((s, t) => s + t.cost, 0);
const annualTotal = monthlyTotal * 12;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/artemis-icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/gallery/01-today.jpg" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Brand fonts — Philosopher (headings) + Karla (body/UI). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Karla:wght@300;400;500;600;700;800&family=Philosopher:wght@400;700&display=swap"
    />

    <style is:global>
      html { scroll-behavior:smooth; }
      body { margin:0; background:#fff; font-family:'Karla',system-ui,sans-serif; color:#1B1A22; -webkit-font-smoothing:antialiased; }
      *{ box-sizing:border-box; }
      img { max-width:100%; }

      @keyframes a-mesh { 0%,100%{ transform:translate(0,0) scale(1);} 50%{ transform:translate(4%,3%) scale(1.12);} }
      @keyframes a-mesh2 { 0%,100%{ transform:translate(0,0) scale(1.1);} 50%{ transform:translate(-5%,-3%) scale(1);} }

      /* Scroll reveal */
      .rev { opacity:0; transform:translateY(36px); transition:opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
      .rev.in { opacity:1; transform:none; }

      .tool-row{ cursor:pointer; user-select:none; transition:background .15s, border-color .15s; }
      .tool-row:hover{ border-color:#14B8A6 !important; }
      .tool-row:focus-visible{ outline:2px solid #14B8A6; outline-offset:2px; }
      .navlink{ font-size:13px; font-weight:600; color:#494E63; text-decoration:none; transition:color .15s; }
      .navlink:hover{ color:#14B8A6; }
      .btn-primary{ transition:transform .2s, box-shadow .2s, background .2s; }
      .btn-primary:hover{ transform:translateY(-2px); box-shadow:0 14px 34px rgba(20,184,166,0.4); }
      .form-input::placeholder{ color:rgba(255,255,255,0.45); }
      .form-input:focus{ border-color:rgba(20,184,166,0.7); background:rgba(255,255,255,0.1); }
      #intg-track{ display:flex; gap:18px; width:max-content; }

      @media (max-width:980px){
        .calc-grid{ grid-template-columns:1fr !important; }
        .verb-grid{ grid-template-columns:1fr !important; }
        .cat-grid{ grid-template-columns:1fr !important; }
        .today-card{ grid-template-columns:1fr !important; }
        .today-card .today-media{ min-height:240px !important; }
      }
      @media (max-width:720px){
        .navlinks{ display:none !important; }
        .stats-grid{ grid-template-columns:1fr 1fr !important; }
        .hero-cta{ flex-direction:column !important; }
        .form-row{ grid-template-columns:1fr !important; }
      }
      @media (max-width:460px){ .stats-grid{ grid-template-columns:1fr !important; } }

      @media (prefers-reduced-motion: reduce){
        *{ animation:none !important; }
        .rev{ opacity:1 !important; transform:none !important; transition:none !important; }
        html{ scroll-behavior:auto; }
      }
    </style>
    <noscript><style>.rev{opacity:1 !important; transform:none !important;}</style></noscript>
  </head>
  <body>

<div style="overflow-x:hidden;">

<!-- ===== NAV ===== -->
<nav style="position:fixed; top:0; left:0; right:0; z-index:200; backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); background:rgba(255,255,255,0.8); border-bottom:1px solid rgba(27,26,34,0.07);">
  <div style="max-width:1180px; margin:0 auto; height:58px; padding:0 24px; display:flex; align-items:center; justify-content:space-between;">
    <a href="#top" style="display:flex; align-items:center; gap:9px; text-decoration:none;">
      <img src="/mark.png" alt="Artemis" width="160" height="160" style="height:27px; width:auto; display:block;" />
      <span style="font-family:'Philosopher',serif; font-weight:700; font-size:18px; color:#1B1A22;">Artemis <span style="color:#14B8A6;">Ortho App</span></span>
    </a>
    <div class="navlinks" style="display:flex; align-items:center; gap:28px;">
      <a class="navlink" href="#calculator">Calculator</a>
      <a class="navlink" href="#replace">What we replace</a>
      <a class="navlink" href="#product">Product</a>
      <a class="navlink" href="#demo">Pricing</a>
      <a class="btn-primary" href="#demo" style="display:inline-flex; align-items:center; padding:8px 18px; border-radius:980px; background:#14B8A6; color:#fff; font-size:13px; font-weight:800; text-decoration:none;">Request demo</a>
    </div>
  </div>
</nav>

<!-- ===== HERO ===== -->
<section id="top" style="position:relative; padding:150px 24px 90px; text-align:center; overflow:hidden; background:linear-gradient(180deg,#1B1A22 0%, #211F2B 60%, #14121A 100%); color:#fff;">
  <div style="position:absolute; inset:0; z-index:0; overflow:hidden;">
    <div style="position:absolute; top:-20%; left:-8%; width:55%; height:85%; background:radial-gradient(closest-side, rgba(20,184,166,0.4), transparent 70%); filter:blur(60px); animation:a-mesh 22s ease-in-out infinite;"></div>
    <div style="position:absolute; bottom:-25%; right:-10%; width:60%; height:90%; background:radial-gradient(closest-side, rgba(20,184,166,0.22), transparent 70%); filter:blur(70px); animation:a-mesh2 26s ease-in-out infinite;"></div>
  </div>
  <div style="position:relative; z-index:1; max-width:940px; margin:0 auto;">
    <div class="rev" style="display:inline-flex; align-items:center; gap:8px; padding:7px 16px; border-radius:980px; background:rgba(20,184,166,0.12); border:1px solid rgba(20,184,166,0.35); font-size:12px; font-weight:700; letter-spacing:.05em; color:#5EEAD4; margin-bottom:28px;">
      <span style="width:6px; height:6px; border-radius:50%; background:#14B8A6; box-shadow:0 0 8px #14B8A6;"></span>
      ONE PLATFORM · 15+ TOOLS REPLACED
    </div>
    <h1 class="rev" style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(42px,6.6vw,82px); line-height:1.02; letter-spacing:-0.025em; margin:0 0 24px;">
      Your whole practice,<br />on <span style="color:#14B8A6;">one platform.</span>
    </h1>
    <p class="rev" style="font-size:clamp(17px,2.1vw,22px); line-height:1.5; color:rgba(255,255,255,0.72); max-width:680px; margin:0 auto 14px;">
      Artemis replaces the 15+ disconnected tools orthodontic practices juggle — analytics, communication, marketing, financials, insurance, and more — with one calm system that runs itself.
    </p>
    <!-- animated savings counter -->
    <div class="rev" style="margin:34px auto 8px; display:inline-flex; flex-direction:column; align-items:center; gap:6px;">
      <div style="font-size:13px; font-weight:700; letter-spacing:.08em; color:rgba(255,255,255,0.5); text-transform:uppercase;">Estimated value unlocked / year</div>
      <div id="hero-counter" data-target={annualTotal} style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(52px,8vw,92px); line-height:1; color:#fff;">{fmt(annualTotal)}</div>
    </div>
    <div class="rev hero-cta" style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin-top:30px;">
      <a class="btn-primary" href="#demo" style="display:inline-flex; align-items:center; padding:14px 30px; border-radius:980px; background:#14B8A6; color:#fff; font-size:16px; font-weight:800; text-decoration:none; box-shadow:0 10px 30px rgba(20,184,166,0.38);">Request a demo</a>
      <a href="#calculator" style="display:inline-flex; align-items:center; gap:6px; padding:14px 26px; border-radius:980px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.2); color:#fff; font-size:16px; font-weight:700; text-decoration:none;">Calculate your savings ↓</a>
    </div>
  </div>
</section>

<!-- ===== STATS BAND ===== -->
<section style="background:#14121A; color:#fff; padding:54px 24px; border-top:1px solid rgba(255,255,255,0.06);">
  <div class="rev stats-grid" style="max-width:1100px; margin:0 auto; display:grid; grid-template-columns:repeat(4,1fr); gap:30px; text-align:center;">
    <div><div style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(34px,4.5vw,52px); color:#14B8A6; line-height:1;">15+</div><div style="font-size:14px; color:rgba(255,255,255,0.6); margin-top:8px;">tools replaced</div></div>
    <div><div style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(34px,4.5vw,52px); color:#14B8A6; line-height:1;">21</div><div style="font-size:14px; color:rgba(255,255,255,0.6); margin-top:8px;">background jobs running 24/7</div></div>
    <div><div style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(34px,4.5vw,52px); color:#14B8A6; line-height:1;">80+</div><div style="font-size:14px; color:rgba(255,255,255,0.6); margin-top:8px;">staff hours saved / month</div></div>
    <div><div style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(34px,4.5vw,52px); color:#14B8A6; line-height:1;">20+</div><div style="font-size:14px; color:rgba(255,255,255,0.6); margin-top:8px;">integrations connected</div></div>
  </div>
</section>

<!-- ===== VALUE CALCULATOR ===== -->
<section id="calculator" style="background:#F7F8F9; padding:110px 24px;">
  <div class="rev" style="max-width:760px; margin:0 auto 50px; text-align:center;">
    <div style="font-size:13px; font-weight:800; letter-spacing:.08em; color:#14B8A6; text-transform:uppercase; margin-bottom:14px;">Value calculator</div>
    <h2 style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(30px,4.6vw,50px); line-height:1.05; letter-spacing:-0.02em; margin:0 0 16px; color:#1B1A22;">What are you paying for all this today?</h2>
    <p style="font-size:18px; line-height:1.55; color:#5A6072; margin:0;">Uncheck anything you don’t use. Watch your real monthly stack add up — then see it collapse into one platform.</p>
  </div>

  <div class="calc-grid" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1.25fr 0.75fr; gap:28px; align-items:start;">
    <!-- tool checklist -->
    <div id="calc-list" style="background:#fff; border:1px solid #E8EAED; border-radius:18px; padding:16px; box-shadow:0 18px 50px rgba(27,26,34,0.06);">
      {tools.map((t) => (
        <div class="tool-row" data-k={t.k} data-cost={t.cost} data-on="1" style="display:flex; align-items:center; gap:14px; padding:14px 16px; border:1px solid transparent; border-radius:12px;">
          <div class="tool-box" style="flex-shrink:0; width:22px; height:22px; border-radius:6px; border:2px solid #14B8A6; background:#14B8A6; display:flex; align-items:center; justify-content:center; color:#fff; font-size:13px; font-weight:900;">✓</div>
          <div style="flex:1; min-width:0;">
            <div style="font-size:15px; font-weight:700; color:#1B1A22;">{t.name}</div>
            <div style="font-size:12px; color:#9CA3AF;">{t.eg}</div>
          </div>
          <div class="tool-amt" style="flex-shrink:0; font-size:14px; font-weight:800; color:#1B1A22;">{fmt(t.cost)}/mo</div>
        </div>
      ))}
    </div>

    <!-- result panel -->
    <div style="position:sticky; top:80px; display:flex; flex-direction:column; gap:16px;">
      <div style="background:#1B1A22; color:#fff; border-radius:18px; padding:26px; box-shadow:0 18px 50px rgba(27,26,34,0.18);">
        <div style="font-size:13px; font-weight:700; letter-spacing:.06em; color:rgba(255,255,255,0.55); text-transform:uppercase;">You pay today</div>
        <div style="display:flex; align-items:baseline; gap:8px; margin-top:6px;">
          <span id="calc-monthly" style="font-family:'Philosopher',serif; font-weight:700; font-size:48px; line-height:1;">{fmt(monthlyTotal)}</span>
          <span style="font-size:15px; color:rgba(255,255,255,0.5);">/mo</span>
        </div>
        <div style="font-size:14px; color:rgba(255,255,255,0.6); margin-top:6px;">≈ <b id="calc-annual" style="color:#fff;">{fmt(annualTotal)}</b>/yr across <b id="calc-count" style="color:#fff;">{tools.length}</b> tools</div>
        <div style="height:1px; background:rgba(255,255,255,0.12); margin:20px 0;"></div>
        <div style="display:flex; align-items:center; gap:10px;">
          <img src="/mark-white.png" alt="Artemis" style="height:22px;" />
          <div style="font-size:14px; font-weight:700;">Artemis replaces all of it</div>
        </div>
        <div style="font-size:13px; color:rgba(255,255,255,0.6); margin-top:8px; line-height:1.5;">One platform. One predictable fee. 21 jobs working around the clock so your team doesn’t.</div>
        <a class="btn-primary" href="#demo" style="display:flex; align-items:center; justify-content:center; margin-top:18px; padding:13px; border-radius:12px; background:#14B8A6; color:#fff; font-size:15px; font-weight:800; text-decoration:none;">See your savings →</a>
      </div>
      <div style="background:rgba(20,184,166,0.1); border:1px solid rgba(20,184,166,0.3); border-radius:14px; padding:16px 18px; text-align:center;">
        <div style="font-size:13px; color:#0F766E; font-weight:700;">Practices typically save</div>
        <div style="font-family:'Philosopher',serif; font-weight:700; font-size:26px; color:#0F766E;">$49,800–99,000<span style="font-size:14px; font-weight:600;">/yr</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ===== WHAT WE REPLACE ===== -->
<section id="replace" style="background:#fff; padding:110px 24px;">
  <div class="rev" style="max-width:760px; margin:0 auto 56px; text-align:center;">
    <div style="font-size:13px; font-weight:800; letter-spacing:.08em; color:#14B8A6; text-transform:uppercase; margin-bottom:14px;">The whole stack, replaced</div>
    <h2 style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(30px,4.6vw,50px); line-height:1.05; letter-spacing:-0.02em; margin:0 0 16px; color:#1B1A22;">Eleven categories. One login.</h2>
    <p style="font-size:18px; line-height:1.55; color:#5A6072; margin:0;">Every row is a tool — and a bill — you can retire the day you switch.</p>
  </div>

  <div class="rev cat-grid" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:16px;">
    {categories.map((c) => (
      <div style="display:flex; align-items:center; gap:16px; background:#F7F8F9; border:1px solid #EBEDF0; border-radius:14px; padding:18px 20px;">
        <div style="flex-shrink:0; width:44px; height:44px; border-radius:11px; background:rgba(20,184,166,0.12); display:flex; align-items:center; justify-content:center; color:#14B8A6; font-size:20px; font-weight:800;">{c.icon}</div>
        <div style="flex:1; min-width:0;">
          <div style="font-size:15px; font-weight:700; color:#1B1A22;">{c.title}</div>
          <div style="font-size:13px; color:#9CA3AF;"><span style="text-decoration:line-through;">{c.replaces}</span> → <span style="color:#14B8A6; font-weight:700;">Artemis</span></div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ===== INTEGRATIONS ===== -->
<section style="background:#14121A; color:#fff; padding:80px 0; overflow:hidden;">
  <div class="rev" style="max-width:1080px; margin:0 auto 40px; padding:0 24px; text-align:center;">
    <div style="font-size:13px; font-weight:800; letter-spacing:.08em; color:#14B8A6; text-transform:uppercase; margin-bottom:14px;">20+ integrations</div>
    <h2 style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(26px,4vw,42px); line-height:1.08; letter-spacing:-0.02em; margin:0; color:#fff;">Connected to the tools you already run on.</h2>
  </div>
  <div style="position:relative; width:100%; overflow:hidden; -webkit-mask:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent); mask:linear-gradient(90deg,transparent,#000 8%,#000 92%,transparent);">
    <div id="intg-track" style="display:flex; gap:18px; width:max-content; padding:0 9px;">
      {integrations.map((g) => (
        <div style="flex-shrink:0; display:flex; align-items:center; gap:10px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:14px 22px; white-space:nowrap;">
          <span style="width:9px; height:9px; border-radius:50%; background:#14B8A6;"></span>
          <span style="font-size:15px; font-weight:700; color:rgba(255,255,255,0.85);">{g}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== 5-VERB PRODUCT ===== -->
<section id="product" style="background:#F7F8F9; padding:110px 24px;">
  <div class="rev" style="max-width:760px; margin:0 auto 64px; text-align:center;">
    <div style="font-size:13px; font-weight:800; letter-spacing:.08em; color:#14B8A6; text-transform:uppercase; margin-bottom:14px;">The product</div>
    <h2 style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(30px,4.6vw,50px); line-height:1.05; letter-spacing:-0.02em; margin:0 0 16px; color:#1B1A22;">Five verbs run the whole practice.</h2>
    <p style="font-size:18px; line-height:1.55; color:#5A6072; margin:0;">Today, People, Growth, Money, and Operations — one architecture your whole team already understands.</p>
  </div>

  <div class="verb-grid" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:22px;">
    <!-- Today — featured wide card -->
    <div class="rev today-card" style="grid-column:1 / -1; background:#1B1A22; color:#fff; border-radius:20px; overflow:hidden; display:grid; grid-template-columns:1fr 1fr; gap:0;">
      <div style="padding:40px;">
