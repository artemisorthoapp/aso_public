---
// Landing page — ported from the "Artemis Ortho website redesign" Claude Design
// doc ("Artemis Ortho Website.dc.html"). Self-contained single-page design with
// its own fixed nav + footer, so it intentionally does NOT use Base/Nav/Footer.
// The Claude-Design runtime (<x-dc>, support.js, _ds stylesheet, DCLogic) has
// been stripped; the signup form posts to the real /api/trial Pages Function and
// scroll-reveal runs as a plain client script.
const title = "Artemis Ortho App — your whole practice, briefed by morning";
const description =
  "Artemis reads your Cloud 9 data overnight — verifies insurance, reconciles the day, and hands your team the three things that actually need them. A briefing, not a dashboard.";
const canonical = new URL("/", Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/artemis-icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Karla:wght@300;400;500;600;700;800&family=Philosopher:wght@400;700&display=swap"
    />

    <style is:global>
      html { scroll-behavior:smooth; }
      body { margin:0; background:#fff; font-family:'Karla',system-ui,sans-serif; color:#24232D; -webkit-font-smoothing:antialiased; }
      @keyframes ao-float { 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-12px); } }
      @keyframes ao-mesh { 0%{ transform:translate(0,0) scale(1);} 50%{ transform:translate(4%,3%) scale(1.12);} 100%{ transform:translate(0,0) scale(1);} }
      @keyframes ao-mesh2 { 0%{ transform:translate(0,0) scale(1.1);} 50%{ transform:translate(-5%,-3%) scale(1);} 100%{ transform:translate(0,0) scale(1.1);} }
      @keyframes ao-pulse { 0%,100%{ opacity:.55;} 50%{ opacity:1;} }
      @keyframes ao-shimmer { 0%{ background-position:-200% 0;} 100%{ background-position:200% 0;} }
      @keyframes ao-blink { 0%,49%{ opacity:1;} 50%,100%{ opacity:0;} }
      @keyframes ao-rise { 0%{ transform:translateY(8px); opacity:0;} 100%{ transform:translateY(0); opacity:1;} }
      @keyframes ao-bar { 0%{ transform:scaleY(.2);} 100%{ transform:scaleY(1);} }
    </style>
    <noscript><style>[data-reveal]{opacity:1 !important; transform:none !important;}</style></noscript>
  </head>
  <body>

<div style="overflow-x:hidden;">

<!-- ===== NAV ===== -->
<nav style="position:fixed; top:0; left:0; right:0; z-index:100; backdrop-filter:saturate(180%) blur(20px); -webkit-backdrop-filter:saturate(180%) blur(20px); background:rgba(255,255,255,0.72); border-bottom:1px solid rgba(36,35,45,0.07);">
  <div style="max-width:1120px; margin:0 auto; height:54px; padding:0 24px; display:flex; align-items:center; justify-content:space-between;">
    <a href="#top" style="display:flex; align-items:center; text-decoration:none;">
      <img src="/artemis-logo.png" alt="Artemis Ortho App" width="900" height="274" style="height:30px; width:auto; display:block;">
    </a>
    <div style="display:flex; align-items:center; gap:28px;">
      <a href="/features" style="font-size:13px; font-weight:600; color:#494E63; text-decoration:none;">Features</a>
      <a href="#product" style="font-size:13px; font-weight:600; color:#494E63; text-decoration:none;">Product</a>
      <a href="#results" style="font-size:13px; font-weight:600; color:#494E63; text-decoration:none;">Results</a>
      <a href="/about" style="font-size:13px; font-weight:600; color:#494E63; text-decoration:none;">About</a>
      <a href="#demo" style="display:inline-flex; align-items:center; padding:7px 16px; border-radius:980px; background:#67A4A1; color:#fff; font-size:13px; font-weight:800; text-decoration:none;">Sign up free</a>
    </div>
  </div>
</nav>

<!-- ===== HERO ===== -->
<section id="top" style="position:relative; background:#16161C; color:#fff; padding:140px 24px 80px; overflow:hidden;">
  <div style="position:absolute; inset:0; overflow:hidden; z-index:0;">
    <div style="position:absolute; top:-20%; left:-10%; width:70%; height:90%; background:radial-gradient(closest-side, rgba(105,201,204,0.45), transparent 70%); filter:blur(40px); animation:ao-mesh 18s ease-in-out infinite;"></div>
    <div style="position:absolute; bottom:-30%; right:-15%; width:75%; height:100%; background:radial-gradient(closest-side, rgba(103,164,161,0.5), transparent 70%); filter:blur(50px); animation:ao-mesh2 22s ease-in-out infinite;"></div>
    <div style="position:absolute; top:30%; right:25%; width:40%; height:50%; background:radial-gradient(closest-side, rgba(237,131,209,0.18), transparent 70%); filter:blur(50px); animation:ao-mesh 26s ease-in-out infinite;"></div>
  </div>

  <div style="position:relative; z-index:1; max-width:920px; margin:0 auto; text-align:center;">
    <div data-reveal style="opacity:0; transform:translateY(24px); transition:all .8s cubic-bezier(0.16,1,0.3,1); display:inline-flex; align-items:center; gap:8px; padding:6px 14px; border-radius:980px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.14); font-size:12px; font-weight:700; letter-spacing:.04em; color:#B4E3E5; margin-bottom:28px;">
      <span style="width:6px; height:6px; border-radius:50%; background:#69C9CC; box-shadow:0 0 8px #69C9CC;"></span>
      OFFICIAL CLOUD 9 ORTHO PARTNER
    </div>
    <h1 data-reveal style="opacity:0; transform:translateY(24px); transition:all .8s cubic-bezier(0.16,1,0.3,1) .08s; font-family:'Philosopher',serif; font-weight:700; font-size:clamp(44px,7vw,84px); line-height:1.02; letter-spacing:-0.02em; margin:0 0 22px;">
      Your whole practice,<br><span style="background:linear-gradient(120deg,#69C9CC,#67A4A1 55%,#B4E3E5); -webkit-background-clip:text; background-clip:text; color:transparent;">briefed by morning.</span>
    </h1>
    <p data-reveal style="opacity:0; transform:translateY(24px); transition:all .8s cubic-bezier(0.16,1,0.3,1) .16s; font-size:clamp(17px,2.2vw,22px); line-height:1.5; color:rgba(255,255,255,0.72); max-width:660px; margin:0 auto 36px;">
      Artemis reads Cloud 9 overnight — verifies insurance, reconciles the day, and hands your team the three things that actually need them. No dashboards to dig through. No double entry.
    </p>
    <div data-reveal style="opacity:0; transform:translateY(24px); transition:all .8s cubic-bezier(0.16,1,0.3,1) .24s; display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
      <a href="#demo" style="display:inline-flex; align-items:center; padding:13px 28px; border-radius:980px; background:#67A4A1; color:#fff; font-size:16px; font-weight:800; text-decoration:none; box-shadow:0 8px 30px rgba(103,164,161,0.4);">Sign up free</a>
      <a href="#features" style="display:inline-flex; align-items:center; gap:6px; padding:13px 24px; border-radius:980px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.18); color:#fff; font-size:16px; font-weight:700; text-decoration:none;">See how it works →</a>
    </div>
  </div>

  <!-- App demo mockup -->
  <div data-reveal style="opacity:0; transform:translateY(40px); transition:all 1s cubic-bezier(0.16,1,0.3,1) .3s; position:relative; z-index:1; max-width:980px; margin:64px auto 0;">
    <div style="animation:ao-float 7s ease-in-out infinite;">
      <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.12); border-radius:18px; padding:10px; box-shadow:0 40px 90px rgba(0,0,0,0.5);">
        <div style="background:#FBFBFC; border-radius:11px; overflow:hidden;">
          <!-- app top bar -->
          <div style="display:flex; align-items:center; gap:8px; padding:13px 18px; border-bottom:1px solid #EEE; background:#fff;">
            <span style="width:11px; height:11px; border-radius:50%; background:#FF5F57;"></span>
            <span style="width:11px; height:11px; border-radius:50%; background:#FEBC2E;"></span>
            <span style="width:11px; height:11px; border-radius:50%; background:#28C840;"></span>
            <div style="flex:1; text-align:center; font-size:12px; color:#9CA3AF; font-weight:600;">app.artemisorthoapp.com</div>
          </div>
          <div style="display:grid; grid-template-columns:200px 1fr; min-height:430px;">
            <!-- sidebar -->
            <div style="background:#1F2230; padding:18px 14px; color:#fff;">
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:24px;">
                <img src="/artemis-icon.png" style="height:22px; filter:brightness(0) invert(1);">
                <span style="font-family:'Philosopher',serif; font-weight:700; font-size:14px;">Artemis</span>
              </div>
              <div style="display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:8px; background:#67A4A1; font-size:13px; font-weight:700; margin-bottom:4px;"><span>◆</span> Briefing</div>
              <div style="display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:8px; color:rgba(255,255,255,0.6); font-size:13px; margin-bottom:4px;"><span>▤</span> Treatment funnel</div>
              <div style="display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:8px; color:rgba(255,255,255,0.6); font-size:13px; margin-bottom:4px;"><span>◇</span> KPIs</div>
              <div style="display:flex; align-items:center; gap:10px; padding:9px 12px; border-radius:8px; color:rgba(255,255,255,0.6); font-size:13px; margin-bottom:4px;"><span>⟲</span> Automations</div>
              <div style="margin-top:auto; padding-top:120px;">
                <div style="background:rgba(255,255,255,0.06); border-radius:10px; padding:11px; font-size:11px; color:rgba(255,255,255,0.55); line-height:1.4;">Synced with Cloud 9<br><span style="color:#69C9CC; font-weight:700;">● 4 min ago</span></div>
              </div>
            </div>
            <!-- main -->
            <div style="padding:22px 24px; background:#FBFBFC; text-align:left;">
              <div style="font-size:12px; color:#9CA3AF; font-weight:600; letter-spacing:.04em;">TUESDAY, JUNE 23</div>
              <div style="font-family:'Philosopher',serif; font-weight:700; font-size:24px; color:#24232D; margin:2px 0 4px;">Good morning, Dr. Lane</div>
              <div style="font-size:13px; color:#6B7280; margin-bottom:18px;">3 things need you today.</div>

              <div style="display:flex; flex-direction:column; gap:10px;">
                <div style="display:flex; gap:12px; align-items:flex-start; background:#fff; border:1px solid #EEE; border-left:3px solid #ED83D1; border-radius:10px; padding:13px 15px; animation:ao-rise .6s ease-out both;">
                  <div style="width:30px; height:30px; border-radius:8px; background:#FCEBF7; display:flex; align-items:center; justify-content:center; color:#ED83D1; font-weight:800; flex-shrink:0;">!</div>
                  <div><div style="font-size:13px; font-weight:700; color:#24232D;">2 contracts aging past 14 days</div><div style="font-size:12px; color:#6B7280;">$11,400 in pending starts. Tap to review &amp; nudge.</div></div>
                </div>
                <div style="display:flex; gap:12px; align-items:flex-start; background:#fff; border:1px solid #EEE; border-left:3px solid #67A4A1; border-radius:10px; padding:13px 15px; animation:ao-rise .6s ease-out .12s both;">
                  <div style="width:30px; height:30px; border-radius:8px; background:#E0F5F5; display:flex; align-items:center; justify-content:center; color:#67A4A1; font-weight:800; flex-shrink:0;">↑</div>
                  <div><div style="font-size:13px; font-weight:700; color:#24232D;">Same-day start rate up to 71%</div><div style="font-size:12px; color:#6B7280;">+9 pts vs last week. 4 exams convert-ready.</div></div>
                </div>
                <div style="display:flex; gap:12px; align-items:flex-start; background:#fff; border:1px solid #EEE; border-left:3px solid #696C8B; border-radius:10px; padding:13px 15px; animation:ao-rise .6s ease-out .24s both;">
                  <div style="width:30px; height:30px; border-radius:8px; background:#EEE; display:flex; align-items:center; justify-content:center; color:#696C8B; font-weight:800; flex-shrink:0;">⟲</div>
                  <div><div style="font-size:13px; font-weight:700; color:#24232D;">3 no-show recovery texts ready</div><div style="font-size:12px; color:#6B7280;">Drafted &amp; waiting for your one-tap approval.</div></div>
                </div>
              </div>

              <div style="margin-top:18px; display:flex; align-items:center; gap:10px; background:#fff; border:1px solid #E5E7EB; border-radius:980px; padding:11px 16px;">
                <span style="color:#67A4A1; font-weight:800;">✦</span>
                <span style="font-size:13px; color:#9CA3AF;">Ask Artemis — “who hasn’t signed in 7+ days?”</span>
                <span style="width:2px; height:15px; background:#67A4A1; animation:ao-blink 1.1s step-end infinite; margin-left:-4px;"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== TRUST STRIP ===== -->
<section style="background:#fff; padding:46px 24px; border-bottom:1px solid #F2F0F3;">
  <div data-reveal style="opacity:0; transform:translateY(20px); transition:all .7s cubic-bezier(0.16,1,0.3,1); max-width:1000px; margin:0 auto; display:flex; align-items:center; justify-content:center; gap:48px; flex-wrap:wrap; text-align:center;">
    <div style="font-size:13px; font-weight:600; color:#9CA3AF; max-width:200px;">Connects directly to your Cloud 9 practice-management data</div>
    <div style="display:flex; align-items:baseline; gap:8px;"><span style="font-family:'Philosopher',serif; font-weight:700; font-size:34px; color:#67A4A1;">6+</span><span style="font-size:13px; color:#6B7280; max-width:120px; text-align:left;">hours handed back per team, weekly</span></div>
    <div style="display:flex; align-items:baseline; gap:8px;"><span style="font-family:'Philosopher',serif; font-weight:700; font-size:34px; color:#67A4A1;">0</span><span style="font-size:13px; color:#6B7280; max-width:120px; text-align:left;">manual eligibility calls</span></div>
    <div style="display:flex; align-items:baseline; gap:8px;"><span style="font-family:'Philosopher',serif; font-weight:700; font-size:34px; color:#67A4A1;">3</span><span style="font-size:13px; color:#6B7280; max-width:120px; text-align:left;">things per role, every morning</span></div>
  </div>
</section>

<!-- ===== FEATURES ===== -->
<section id="features" style="background:#fff; padding:120px 24px 40px;">
  <div data-reveal style="opacity:0; transform:translateY(24px); transition:all .8s cubic-bezier(0.16,1,0.3,1); max-width:780px; margin:0 auto 90px; text-align:center;">
    <div style="font-size:13px; font-weight:800; letter-spacing:.08em; color:#67A4A1; text-transform:uppercase; margin-bottom:16px;">What Artemis does</div>
    <h2 style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(32px,5vw,52px); line-height:1.06; letter-spacing:-0.02em; margin:0 0 18px; color:#24232D;">A briefing, not a dashboard.</h2>
    <p style="font-size:19px; line-height:1.55; color:#6B7280; margin:0;">Staff spend time on patients, not paperwork. Here’s the layer working quietly underneath.</p>
  </div>

  <!-- feature rows -->
  <div style="max-width:1080px; margin:0 auto; display:flex; flex-direction:column; gap:110px;">

    <div data-reveal style="opacity:0; transform:translateY(40px); transition:all .9s cubic-bezier(0.16,1,0.3,1); display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
      <div>
        <div style="font-size:13px; font-weight:800; letter-spacing:.06em; color:#ED83D1; text-transform:uppercase; margin-bottom:14px;">Per role, per morning</div>
        <h3 style="font-family:'Philosopher',serif; font-weight:700; font-size:34px; line-height:1.1; letter-spacing:-0.01em; margin:0 0 16px; color:#24232D;">The three things that need you today.</h3>
        <p style="font-size:17px; line-height:1.6; color:#6B7280; margin:0;">Every role opens to a short, ranked list — aging contracts, convert-ready exams, recovery texts waiting on a tap. No hunting through tabs. Just what moves the practice forward, prioritized.</p>
      </div>
      <div style="background:linear-gradient(160deg,#F2F0F3,#fff); border:1px solid #EEE; border-radius:18px; padding:24px; box-shadow:0 20px 50px rgba(36,35,45,0.07);">
        <div style="display:flex; flex-direction:column; gap:12px;">
          <div style="display:flex; gap:12px; align-items:center; background:#fff; border:1px solid #EEE; border-left:3px solid #ED83D1; border-radius:10px; padding:14px;"><div style="width:34px;height:34px;border-radius:9px;background:#FCEBF7;display:flex;align-items:center;justify-content:center;color:#ED83D1;font-weight:800;">!</div><div style="font-size:14px;font-weight:700;color:#24232D;">2 contracts aging 14+ days<div style="font-size:12px;font-weight:400;color:#9CA3AF;">$11,400 pending</div></div></div>
          <div style="display:flex; gap:12px; align-items:center; background:#fff; border:1px solid #EEE; border-left:3px solid #67A4A1; border-radius:10px; padding:14px;"><div style="width:34px;height:34px;border-radius:9px;background:#E0F5F5;display:flex;align-items:center;justify-content:center;color:#67A4A1;font-weight:800;">↑</div><div style="font-size:14px;font-weight:700;color:#24232D;">4 exams convert-ready<div style="font-size:12px;font-weight:400;color:#9CA3AF;">Same-day start opportunity</div></div></div>
          <div style="display:flex; gap:12px; align-items:center; background:#fff; border:1px solid #EEE; border-left:3px solid #696C8B; border-radius:10px; padding:14px;"><div style="width:34px;height:34px;border-radius:9px;background:#EEE;display:flex;align-items:center;justify-content:center;color:#696C8B;font-weight:800;">⟲</div><div style="font-size:14px;font-weight:700;color:#24232D;">3 recovery texts ready<div style="font-size:12px;font-weight:400;color:#9CA3AF;">Waiting on your approval</div></div></div>
        </div>
      </div>
    </div>

    <div data-reveal style="opacity:0; transform:translateY(40px); transition:all .9s cubic-bezier(0.16,1,0.3,1); display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
      <div style="order:2;">
        <div style="font-size:13px; font-weight:800; letter-spacing:.06em; color:#67A4A1; text-transform:uppercase; margin-bottom:14px;">Ortho-real KPIs</div>
        <h3 style="font-family:'Philosopher',serif; font-weight:700; font-size:34px; line-height:1.1; letter-spacing:-0.01em; margin:0 0 16px; color:#24232D;">Metrics that mean something in an ortho practice.</h3>
        <p style="font-size:17px; line-height:1.6; color:#6B7280; margin:0;">Same-day start rate. Pending-contract aging. Chair utilization. Rolling-30 no-show. The numbers your practice actually runs on — not generic SaaS vanity metrics.</p>
      </div>
      <div style="order:1; background:#16161C; border-radius:18px; padding:26px; box-shadow:0 20px 50px rgba(36,35,45,0.18);">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:16px;"><div style="font-size:11px; color:rgba(255,255,255,0.5); font-weight:600;">SAME-DAY START</div><div style="font-family:'Philosopher',serif; font-size:30px; font-weight:700; color:#69C9CC;">71%</div><div style="font-size:11px; color:#69C9CC;">▲ 9 pts</div></div>
          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:16px;"><div style="font-size:11px; color:rgba(255,255,255,0.5); font-weight:600;">CHAIR UTILIZATION</div><div style="font-family:'Philosopher',serif; font-size:30px; font-weight:700; color:#fff;">88%</div><div style="font-size:11px; color:#69C9CC;">▲ 3 pts</div></div>
          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:16px;"><div style="font-size:11px; color:rgba(255,255,255,0.5); font-weight:600;">PENDING AGING</div><div style="font-family:'Philosopher',serif; font-size:30px; font-weight:700; color:#fff;">$11.4k</div><div style="font-size:11px; color:#ED83D1;">2 over 14d</div></div>
          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:16px;"><div style="font-size:11px; color:rgba(255,255,255,0.5); font-weight:600;">NO-SHOW (30d)</div><div style="font-family:'Philosopher',serif; font-size:30px; font-weight:700; color:#fff;">4.2%</div><div style="font-size:11px; color:#69C9CC;">▼ 1.1 pts</div></div>
        </div>
      </div>
    </div>

    <div data-reveal style="opacity:0; transform:translateY(40px); transition:all .9s cubic-bezier(0.16,1,0.3,1); display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
      <div>
        <div style="font-size:13px; font-weight:800; letter-spacing:.06em; color:#67A4A1; text-transform:uppercase; margin-bottom:14px;">Ask Artemis</div>
        <h3 style="font-family:'Philosopher',serif; font-weight:700; font-size:34px; line-height:1.1; letter-spacing:-0.01em; margin:0 0 16px; color:#24232D;">Ask in plain English. Or just say it.</h3>
        <p style="font-size:17px; line-height:1.6; color:#6B7280; margin:0;">“Who hasn’t signed in 7+ days?” “Show me this month’s starts by referral source.” Type it or speak it — Artemis answers from your live Cloud 9 data in seconds.</p>
      </div>
      <div style="background:linear-gradient(160deg,#F2F0F3,#fff); border:1px solid #EEE; border-radius:18px; padding:24px; box-shadow:0 20px 50px rgba(36,35,45,0.07);">
