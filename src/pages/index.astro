---
// Landing page — recreated from the v2 Claude Design handoff
// ("Artemis Ortho Website v2.dc.html" + design_handoff README, Jun 2026).
// Apple-style long-scroll: light hero, full-bleed autoplay product "film",
// dark Automations spotlight, five-verb feature rows on real screenshots, a
// drag-scroll product gallery, a chiclet "and so much more" grid, results
// stats, and the free-signup CTA.
//
// Self-contained single page with its own fixed nav + footer (does NOT use
// Base/Nav/Footer). The Claude-Design runtime (<x-dc>, support.js, DCLogic)
// is stripped: the autoplay film, scroll-reveal and drag-rail run as plain
// inline scripts, and the signup form posts to the real /api/trial Pages
// Function (no client-side fake submit) with a honeypot. All animation is
// gated behind prefers-reduced-motion.
const title = "Artemis Ortho App — total visibility, automatic everything";
const description =
  "Artemis reads your Cloud 9 data overnight, runs the busywork on a schedule, and briefs every role each morning on the few things that need a human. One calm surface for the whole practice.";
const canonical = new URL("/", Astro.site).href;

// Feature verb rows — image side alternates left/right down the column.
const verbs = [
  {
    eyebrow: "Today",
    eyebrowColor: "#ED83D1",
    title: "A briefing that thinks for you.",
    body:
      "Every morning Artemis reads the overnight changes and assembles a role-aware briefing — the exams to confirm, the decisions only a doctor can make, and the quiet wins worth noting. Ask it anything about the practice in plain language.",
    bullets: [
      "Role-aware (Doctor · OM · TC · Coordinator)",
      "Ask Artemis, by text or voice",
      "Anomaly-driven, not noise",
    ],
    img: "/gallery/01-today.jpg",
    alt: "Today briefing",
    imageRight: true,
  },
  {
    eyebrow: "People",
    eyebrowColor: "#67A4A1",
    title: "The treatment funnel, end to end.",
    body:
      "Follow every patient from new lead through exam, consult, and signed contract. See exactly who’s aging at each stage, the pipeline value sitting there, and the one bottleneck stalling starts this week.",
    bullets: [
      "Per-stage counts + aging flags",
      "Scheduling, communication & cases",
      "Insurance eligibility built in",
    ],
    img: "/gallery/02-people-funnel.jpg",
    alt: "Treatment funnel",
    imageRight: false,
  },
  {
    eyebrow: "Growth",
    eyebrowColor: "#67A4A1",
    title: "Know what actually drives starts.",
    body:
      "A channel scoreboard ties leads, referrals, reviews, SEO, and campaigns back to the starts they produce. Plan and generate social content, run review and blog campaigns — all from one place.",
    bullets: [
      "Lead, referral & SEO tracking",
      "Social planner + content generation",
      "Review & blog campaigns",
    ],
    img: "/gallery/08-growth.jpg",
    alt: "Growth scoreboard",
    imageRight: true,
  },
  {
    eyebrow: "Money",
    eyebrowColor: "#67A4A1",
    title: "Production, collections, and AR — straight.",
    body:
      "Cash flow, production against target, and AR aging broken down by payer — with the over-90 bucket called out before it ages out. QuickBooks and day/month close, reconciled for you.",
    bullets: [
      "Production vs. target & cash flow",
      "AR aging 30/60/90 by payer",
      "QuickBooks + day/month close",
    ],
    img: "/gallery/16-money.jpg",
    alt: "Money & cash flow",
    imageRight: false,
  },
  {
    eyebrow: "Operations",
    eyebrowColor: "#ED83D1",
    title: "Chairs, team, and the whole back office.",
    body:
      "Chair utilization and rolling no-show rate, plus inventory, training, payroll, employee reviews, and a TV slideshow for the waiting room — the operational layer most tools never touch.",
    bullets: [
      "Chair utilization & no-show rate",
      "Inventory, training & payroll",
      "Waiting-room TV slideshow",
    ],
    img: "/gallery/19-operations.jpg",
    alt: "Operations",
    imageRight: true,
  },
];

// Autoplay film slides (cross-fade on a timer).
const film = [
  { i: 0, img: "/gallery/01-today.jpg", alt: "Today", eyebrow: "Today", caption: "Every morning, the briefing that needs you." },
  { i: 1, img: "/gallery/02-people-funnel.jpg", alt: "People", eyebrow: "People", caption: "The full treatment funnel, end to end." },
  { i: 2, img: "/gallery/08-growth.jpg", alt: "Growth", eyebrow: "Growth", caption: "See exactly what drives new starts." },
  { i: 3, img: "/gallery/16-money.jpg", alt: "Money", eyebrow: "Money", caption: "Production, collections & AR — clear." },
  { i: 4, img: "/gallery/25-automations.jpg", alt: "Automations", eyebrow: "Automations", caption: "The busywork runs itself, overnight." },
];

// Horizontal drag-scroll gallery cards.
const gallery = [
  { img: "/gallery/09-growth-social-reels.jpg", alt: "Social content", label: "Social planner + content generation" },
  { img: "/gallery/06-people-insurance-check.jpg", alt: "Insurance eligibility", label: "Insurance eligibility & claims" },
  { img: "/gallery/17-money-financials.jpg", alt: "Financials", label: "Financials & production" },
  { img: "/gallery/20-operations-inventory.jpg", alt: "Inventory", label: "Inventory management" },
  { img: "/gallery/28-snap-canva.jpg", alt: "Snap to Canva", label: "Snap → Canva poster" },
  { img: "/gallery/11-growth-seo.jpg", alt: "SEO performance", label: "SEO performance" },
  { img: "/gallery/22-operations-payroll.jpg", alt: "Payroll", label: "Payroll & timesheets" },
];

// "And so much more" chiclets.
const more = [
  { glyph: "✓", title: "Automated eligibility", body: "Insurance verified ahead of the visit — no front-desk phone queue, no surprises at check-in." },
  { glyph: "⇄", title: "Day & month close", body: "Production and collections reconciled automatically, with QuickBooks kept in sync." },
  { glyph: "◷", title: "A briefing per role", body: "Doctor, OM, TC, and front desk each see the few things that need them — not everyone else’s noise." },
  { glyph: "⌂", title: "Records & photo upload", body: "Push intake and progress photos straight to the right Cloud 9 patient chart." },
  { glyph: "⛉", title: "Built for patient data", body: "Official Cloud 9 partner integration, encryption in transit and at rest, role-based access." },
  { glyph: "⚡", title: "Live in days, not quarters", body: "Connect to Cloud 9 and your first briefing lands the next day. No IT project, no migration." },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/artemis-icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Karla:wght@300;400;500;600;700;800&family=Philosopher:wght@400;700&display=swap"
    />

    <style is:global>
      html { scroll-behavior:smooth; }
      body { margin:0; background:#fff; font-family:'Karla',system-ui,sans-serif; color:#24232D; -webkit-font-smoothing:antialiased; }
      img { max-width:100%; }

      @keyframes ao-mesh { 0%,100%{ transform:translate(0,0) scale(1);} 50%{ transform:translate(4%,3%) scale(1.12);} }
      @keyframes ao-mesh2 { 0%,100%{ transform:translate(0,0) scale(1.1);} 50%{ transform:translate(-5%,-3%) scale(1);} }
      @keyframes ao-pulse { 0%,100%{ opacity:.5;} 50%{ opacity:1;} }
      @keyframes ao-ken { from{ transform:scale(1.015) translateY(0);} to{ transform:scale(1.10) translateY(-3.5%);} }

      /* Scroll reveal */
      .ao-rev { opacity:0; transform:translateY(40px); transition:opacity 1s cubic-bezier(.16,1,.3,1), transform 1s cubic-bezier(.16,1,.3,1); }
      .ao-rev.ao-in { opacity:1; transform:none; }

      /* Drag-scroll gallery rail */
      #hl-rail { -ms-overflow-style:none; scrollbar-width:none; }
      #hl-rail::-webkit-scrollbar { display:none; }
      #hl-rail.dragging { cursor:grabbing; scroll-snap-type:none; }

      /* ---- Responsive ---- */
      @media (max-width: 900px){
        .feat-grid{ grid-template-columns:1fr !important; gap:32px !important; }
        .feat-grid > div{ order:0 !important; }
        .auto-2{ grid-template-columns:1fr !important; gap:36px !important; }
        .auto-3{ grid-template-columns:1fr !important; }
      }
      @media (max-width: 720px){
        .nav-links a.navlink{ display:none !important; }
        .more-grid{ grid-template-columns:1fr 1fr !important; gap:32px 28px !important; }
        .stat-grid{ grid-template-columns:1fr !important; gap:44px !important; }
        .footer-row{ flex-direction:column !important; align-items:flex-start !important; }
      }
      @media (max-width: 460px){
        .more-grid{ grid-template-columns:1fr !important; }
        .form-row{ grid-template-columns:1fr !important; }
      }

      @media (prefers-reduced-motion: reduce){
        *{ animation:none !important; }
        .ao-rev{ opacity:1 !important; transform:none !important; transition:none !important; }
        html{ scroll-behavior:auto; }
      }
    </style>
    <noscript><style>.ao-rev{opacity:1 !important; transform:none !important;}</style></noscript>
  </head>
  <body>

<div style="overflow-x:hidden;">

<!-- ===== NAV ===== -->
<nav style="position:fixed; top:0; left:0; right:0; z-index:200; backdrop-filter:saturate(180%) blur(20px); -webkit-backdrop-filter:saturate(180%) blur(20px); background:rgba(255,255,255,0.78); border-bottom:1px solid rgba(36,35,45,0.07);">
  <div style="max-width:1120px; margin:0 auto; height:54px; padding:0 24px; display:flex; align-items:center; justify-content:space-between;">
    <a href="#top" style="display:flex; align-items:center; gap:9px; text-decoration:none;">
      <img src="/mark.png" alt="Artemis" width="160" height="160" style="height:36px; width:auto; display:block;">
      <span style="font-family:'Philosopher',serif; font-weight:700; font-size:20px; color:#24232D;">Artemis <span style="color:#67A4A1;">Ortho App</span></span>
    </a>
    <div class="nav-links" style="display:flex; align-items:center; gap:26px;">
      <a class="navlink" href="#automations" style="font-size:13px; font-weight:600; color:#494E63; text-decoration:none;">Automations</a>
      <a class="navlink" href="#features" style="font-size:13px; font-weight:600; color:#494E63; text-decoration:none;">Features</a>
      <a class="navlink" href="#gallery" style="font-size:13px; font-weight:600; color:#494E63; text-decoration:none;">Product</a>
      <a href="#demo" style="display:inline-flex; align-items:center; padding:7px 16px; border-radius:980px; background:#67A4A1; color:#fff; font-size:13px; font-weight:800; text-decoration:none;">Sign up free</a>
    </div>
  </div>
</nav>

<!-- ===== HERO ===== -->
<section id="top" style="position:relative; padding:150px 24px 70px; text-align:center; overflow:hidden; background:linear-gradient(180deg,#F4FBFB 0%, #EAF6F6 46%, #ffffff 100%);">
  <div style="position:absolute; inset:0; z-index:0; overflow:hidden;">
    <div style="position:absolute; top:-25%; left:8%; width:55%; height:80%; background:radial-gradient(closest-side, rgba(105,201,204,0.4), transparent 70%); filter:blur(50px); animation:ao-mesh 20s ease-in-out infinite;"></div>
    <div style="position:absolute; top:-10%; right:2%; width:50%; height:80%; background:radial-gradient(closest-side, rgba(237,131,209,0.16), transparent 70%); filter:blur(60px); animation:ao-mesh2 24s ease-in-out infinite;"></div>
  </div>
  <div style="position:relative; z-index:1; max-width:920px; margin:0 auto;">
    <div class="ao-rev" style="display:inline-flex; align-items:center; gap:8px; padding:6px 14px; border-radius:980px; background:rgba(255,255,255,0.8); border:1px solid rgba(103,164,161,0.32); font-size:12px; font-weight:700; letter-spacing:.04em; color:#5A908E; margin-bottom:26px;">
      <span style="width:6px; height:6px; border-radius:50%; background:#67A4A1; box-shadow:0 0 8px #69C9CC;"></span>
      OFFICIAL CLOUD 9 ORTHO PARTNER
    </div>
    <h1 class="ao-rev" style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(44px,7.4vw,88px); line-height:1.0; letter-spacing:-0.025em; margin:0 0 22px;">
      Total visibility.<br><span style="background:linear-gradient(120deg,#67A4A1,#69C9CC 55%,#ED83D1); -webkit-background-clip:text; background-clip:text; color:transparent;">Automatic everything.</span>
    </h1>
    <p class="ao-rev" style="font-size:clamp(17px,2.2vw,22px); line-height:1.5; color:#5A6072; max-width:680px; margin:0 auto 34px;">
      Artemis reads your Cloud 9 data overnight, runs the busywork on a schedule, and briefs every role each morning on the few things that need a human. One calm surface for the whole practice.
    </p>
    <div class="ao-rev" style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
      <a href="#demo" style="display:inline-flex; align-items:center; padding:13px 28px; border-radius:980px; background:#67A4A1; color:#fff; font-size:16px; font-weight:800; text-decoration:none; box-shadow:0 8px 28px rgba(103,164,161,0.38);">Sign up free</a>
      <a href="#features" style="display:inline-flex; align-items:center; gap:6px; padding:13px 24px; border-radius:980px; background:#fff; border:1px solid rgba(36,35,45,0.12); color:#24232D; font-size:16px; font-weight:700; text-decoration:none;">Take the tour ↓</a>
    </div>
  </div>
</section>

<!-- ===== FULL-BLEED AUTOPLAY FILM ===== -->
<section style="position:relative; width:100%; background:#0E0E12; overflow:hidden;">
  <div style="position:relative; width:100%; aspect-ratio:1440/900; max-height:88vh; overflow:hidden; background:#0E0E12; margin:0 auto;">
    {film.map((s) => (
      <img class="film-img" data-i={s.i} src={s.img} alt={s.alt} width="1440" height="900" loading={s.i === 0 ? "eager" : "lazy"} decoding="async" style={`position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:top center; opacity:${s.i === 0 ? 1 : 0}; transition:opacity 1s ease;`} />
    ))}

    <!-- LIVE pill -->
    <div style="position:absolute; top:24px; right:28px; z-index:6; display:flex; align-items:center; gap:7px; padding:6px 13px; border-radius:980px; background:rgba(10,10,14,0.5); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); font-size:11px; font-weight:800; letter-spacing:.06em; color:#fff;"><span style="width:7px;height:7px;border-radius:50%;background:#ED83D1; animation:ao-pulse 1.6s infinite;"></span>LIVE</div>

    <!-- segmented progress -->
    <div style="position:absolute; top:24px; left:28px; right:120px; display:flex; gap:7px; z-index:6;">
      {film.map((s) => (
        <div style="flex:1; height:3px; border-radius:3px; background:rgba(255,255,255,0.3); overflow:hidden;"><div class="film-fill" data-i={s.i} style="width:0%; height:100%; background:#fff; border-radius:3px;"></div></div>
      ))}
    </div>

    <!-- caption overlay -->
    <div style="position:absolute; left:0; right:0; bottom:0; padding:56px clamp(28px,6vw,90px) 48px; text-align:left; background:linear-gradient(0deg, rgba(10,10,14,0.9) 6%, rgba(10,10,14,0.45) 48%, transparent); z-index:5;">
      <div id="film-eye" style="font-size:13px; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color:#69C9CC; margin-bottom:10px; transition:opacity .4s;">Today</div>
      <div id="film-cap" style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(24px,3.6vw,46px); line-height:1.1; letter-spacing:-0.01em; color:#fff; max-width:780px; transition:opacity .4s;">Every morning, the briefing that needs you.</div>
    </div>
  </div>
</section>

<!-- ===== AUTOMATIONS SPOTLIGHT ===== -->
<section id="automations" style="position:relative; background:#0E0E12; color:#fff; padding:120px 24px;">
  <div style="max-width:1120px; margin:0 auto;">
    <div class="ao-rev" style="max-width:760px; margin:0 auto 70px; text-align:center;">
      <div style="font-size:13px; font-weight:800; letter-spacing:.1em; color:#ED83D1; text-transform:uppercase; margin-bottom:16px;">Automations</div>
      <h2 style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(34px,5.2vw,58px); line-height:1.04; letter-spacing:-0.02em; margin:0 0 18px;">The work that used to wait for someone — now just happens.</h2>
      <p style="font-size:19px; line-height:1.55; color:rgba(255,255,255,0.66); margin:0;">Schedules run jobs overnight. Event-driven reminders fire the moment something changes in Cloud 9. Nothing that touches a patient sends without a human tap.</p>
    </div>

    <!-- big screenshot: job schedules -->
    <div class="ao-rev" style="margin:0 auto 90px; max-width:1000px;">
      <div style="border-radius:16px; overflow:hidden; box-shadow:0 50px 110px rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.1); background:#fff;">
        <div style="display:flex; align-items:center; gap:8px; padding:0 16px; height:38px; background:#F4F4F6; border-bottom:1px solid #E6E6E9;">
          <span style="width:11px;height:11px;border-radius:50%;background:#FF5F57;"></span><span style="width:11px;height:11px;border-radius:50%;background:#FEBC2E;"></span><span style="width:11px;height:11px;border-radius:50%;background:#28C840;"></span>
          <div style="flex:1; max-width:380px; margin:0 auto; text-align:center; font-size:12px; color:#9CA3AF; font-weight:600; background:#fff; border-radius:7px; padding:4px 0;">app.artemisorthoapp.com/settings · Job Schedules</div>
        </div>
        <img src="/gallery/25-automations.jpg" alt="Job schedules" width="1440" height="900" loading="lazy" decoding="async" style="display:block; width:100%; height:auto;">
      </div>
    </div>

    <!-- three pillars -->
    <div class="ao-rev auto-3" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin-bottom:90px;">
      <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:28px;">
        <div style="width:44px; height:44px; border-radius:12px; background:rgba(105,201,204,0.16); display:flex; align-items:center; justify-content:center; color:#69C9CC; font-size:20px; margin-bottom:18px;">◷</div>
        <h3 style="font-family:'Philosopher',serif; font-size:21px; margin:0 0 10px;">Scheduled jobs</h3>
        <p style="font-size:14px; line-height:1.6; color:rgba(255,255,255,0.6); margin:0;">Eligibility checks, reconciliation, blog posts, birthday cards — each runs on its own cadence. Change the schedule and it takes effect on the next cycle. No restart.</p>
      </div>
      <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:28px;">
        <div style="width:44px; height:44px; border-radius:12px; background:rgba(237,131,209,0.16); display:flex; align-items:center; justify-content:center; color:#ED83D1; font-size:20px; margin-bottom:18px;">⚡</div>
        <h3 style="font-family:'Philosopher',serif; font-size:21px; margin:0 0 10px;">Event-driven reminders</h3>
        <p style="font-size:14px; line-height:1.6; color:rgba(255,255,255,0.6); margin:0;">Fire on an upstream event — a new Google review, an insurance form submitted, photos uploaded to a chart. Pick who gets notified; no schedule needed.</p>
      </div>
      <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:28px;">
        <div style="width:44px; height:44px; border-radius:12px; background:rgba(103,164,161,0.18); display:flex; align-items:center; justify-content:center; color:#67A4A1; font-size:20px; margin-bottom:18px;">✓</div>
        <h3 style="font-family:'Philosopher',serif; font-size:21px; margin:0 0 10px;">Human in the loop</h3>
        <p style="font-size:14px; line-height:1.6; color:rgba(255,255,255,0.6); margin:0;">Artemis drafts the message and proposes the action — then waits. Nothing reaches a patient until someone on your team approves it.</p>
      </div>
    </div>

    <!-- office reminders screenshot, offset -->
    <div class="ao-rev auto-2" style="display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center;">
      <div>
        <div style="font-size:13px; font-weight:800; letter-spacing:.06em; color:#69C9CC; text-transform:uppercase; margin-bottom:14px;">Office reminders</div>
        <h3 style="font-family:'Philosopher',serif; font-weight:700; font-size:32px; line-height:1.1; margin:0 0 16px;">It notices, so your front desk doesn’t have to.</h3>
        <p style="font-size:16px; line-height:1.6; color:rgba(255,255,255,0.62); margin:0 0 22px;">Insurance auto-update from a submitted form, patient-info changes pushed to Cloud 9, a cycle count finalized in inventory — each one can quietly text or email exactly the right person.</p>
        <div style="display:flex; flex-direction:column; gap:12px;">
          <div style="display:flex; gap:12px; align-items:center; font-size:14px; color:rgba(255,255,255,0.85);"><span style="width:7px;height:7px;border-radius:50%;background:#69C9CC; animation:ao-pulse 1.8s infinite;"></span>Insurance Auto-Update (form → Cloud 9)</div>
          <div style="display:flex; gap:12px; align-items:center; font-size:14px; color:rgba(255,255,255,0.85);"><span style="width:7px;height:7px;border-radius:50%;background:#69C9CC; animation:ao-pulse 1.8s infinite .4s;"></span>Patient Info Update Summary</div>
          <div style="display:flex; gap:12px; align-items:center; font-size:14px; color:rgba(255,255,255,0.85);"><span style="width:7px;height:7px;border-radius:50%;background:#ED83D1; animation:ao-pulse 1.8s infinite .8s;"></span>Inventory Cycle Count Completed</div>
        </div>
      </div>
      <div style="border-radius:14px; overflow:hidden; box-shadow:0 40px 90px rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.1); background:#fff;">
        <div style="display:flex; align-items:center; gap:7px; padding:0 14px; height:34px; background:#F4F4F6; border-bottom:1px solid #E6E6E9;">
          <span style="width:10px;height:10px;border-radius:50%;background:#FF5F57;"></span><span style="width:10px;height:10px;border-radius:50%;background:#FEBC2E;"></span><span style="width:10px;height:10px;border-radius:50%;background:#28C840;"></span>
        </div>
        <img src="/gallery/24-operations-reminders.jpg" alt="Office reminders" width="1440" height="900" loading="lazy" decoding="async" style="display:block; width:100%; height:auto;">
      </div>
    </div>
  </div>
</section>

<!-- ===== FEATURES (five verbs) ===== -->
<section id="features" style="background:#fff; padding:130px 24px 40px;">
  <div class="ao-rev" style="max-width:820px; margin:0 auto 96px; text-align:center;">
    <div style="font-size:13px; font-weight:800; letter-spacing:.08em; color:#67A4A1; text-transform:uppercase; margin-bottom:16px;">Total visibility</div>
    <h2 style="font-family:'Philosopher',serif; font-weight:700; font-size:clamp(32px,5vw,54px); line-height:1.05; letter-spacing:-0.02em; margin:0 0 18px; color:#24232D;">Five verbs. One practice, in focus.</h2>
