---
import Base from "../layouts/Base.astro";

const highlights = [
  {
    title: "Today, in one glance",
    body: "A role-aware morning briefing surfaces what changed overnight and what needs a human today — no dashboard spelunking.",
  },
  {
    title: "A live treatment funnel",
    body: "From new lead to signed contract, see every stage, where patients are aging, and the exact value sitting in your pipeline.",
  },
  {
    title: "The money, honestly",
    body: "Production vs. target, cash flow, and AR aging by payer — the numbers that actually move the practice, updated continuously.",
  },
  {
    title: "Chair & team operations",
    body: "Utilization heatmaps, no-show trends over a rolling 30 days, and the staffing picture behind your schedule.",
  },
];

const verbs = ["Today", "People", "Growth", "Money", "Operations"];
---

<Base>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-brand-50 to-white"
    >
    </div>
    <div class="container-page py-20 sm:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow">For orthodontic practices</p>
        <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-ink sm:text-6xl">
          Run your practice from a single, calm screen.
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-ink-soft">
          Artemis pulls your practice-management data into a daily briefing, a live
          treatment funnel, and the financials that matter — so your team spends
          time on patients, not spreadsheets.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/signup" class="btn-primary px-6 py-3 text-base">Start free trial</a>
          <a href="/features" class="btn-outline px-6 py-3 text-base">See features</a>
        </div>
        <p class="mt-4 text-xs text-ink-soft">No credit card required · Setup in a day</p>
      </div>

      <!-- The 5 verbs strip -->
      <div class="mx-auto mt-14 flex max-w-2xl flex-wrap items-center justify-center gap-2">
        {verbs.map((v) => (
          <span class="rounded-full border border-brand-200 bg-white px-4 py-1.5 text-sm font-medium text-brand-700">
            {v}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Highlights -->
  <section class="container-page py-16 sm:py-20">
    <div class="grid gap-6 sm:grid-cols-2">
      {highlights.map((h) => (
        <div class="rounded-2xl border border-brand-100 bg-white p-7 shadow-sm transition-shadow hover:shadow-md">
          <h2 class="font-display text-xl font-semibold text-ink">{h.title}</h2>
          <p class="mt-2 text-ink-soft">{h.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Tiers teaser -->
  <section class="border-y border-brand-100 bg-brand-50/40">
    <div class="container-page py-16 text-center sm:py-20">
      <h2 class="font-display text-3xl font-bold text-ink">Pricing that grows with you</h2>
      <p class="mx-auto mt-3 max-w-xl text-ink-soft">
        Start on a single office and scale to a multi-location group — same dashboard,
        more horsepower.
      </p>
      <a href="/pricing" class="btn-primary mt-7 px-6 py-3 text-base">View pricing</a>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="container-page py-20 text-center">
    <h2 class="font-display text-3xl font-bold text-ink sm:text-4xl">
      See it on your own numbers.
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-ink-soft">
      Connect your practice management system and watch your funnel, schedule, and
      financials come to life.
    </p>
    <a href="/signup" class="btn-primary mt-7 px-6 py-3 text-base">Start free trial</a>
  </section>
</Base>
