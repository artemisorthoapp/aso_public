<script is:inline>
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- Scroll reveal ----
    var revs = document.querySelectorAll('.ao-rev');
    if (reduce || !('IntersectionObserver' in window)) {
      revs.forEach(function (el) { el.classList.add('ao-in'); });
    } else {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('ao-in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      revs.forEach(function (el) { io.observe(el); });
    }

    // ---- Autoplay film ----
    (function () {
      var imgs = [].slice.call(document.querySelectorAll('.film-img'));
      var fills = [].slice.call(document.querySelectorAll('.film-fill'));
      var eye = document.getElementById('film-eye');
      var cap = document.getElementById('film-cap');
      if (!imgs.length) return;
      var caps = [
        ['Today', 'Every morning, the briefing that needs you.'],
        ['People', 'The full treatment funnel, end to end.'],
        ['Growth', 'See exactly what drives new starts.'],
        ['Money', 'Production, collections & AR — clear.'],
        ['Automations', 'The busywork runs itself, overnight.']
      ];
      var dwell = 3600;
      var i = -1;
      function go(k) {
        i = k;
        imgs.forEach(function (im) {
          var on = +im.dataset.i === k;
          im.style.opacity = on ? '1' : '0';
          if (on && !reduce) {
            im.style.animation = 'none'; void im.offsetWidth;
            im.style.animation = 'ao-ken ' + (dwell + 900) + 'ms ease-out forwards';
          }
        });
        if (eye && cap) {
          eye.style.opacity = '0'; cap.style.opacity = '0';
          setTimeout(function () {
            eye.textContent = caps[k][0]; cap.textContent = caps[k][1];
            eye.style.opacity = '1'; cap.style.opacity = '1';
          }, 150);
        }
        fills.forEach(function (f, idx) {
          if (idx < k) { f.style.transition = 'none'; f.style.width = '100%'; }
          else if (idx === k) {
            f.style.transition = 'none'; f.style.width = '0%'; void f.offsetWidth;
            f.style.transition = 'width ' + dwell + 'ms linear'; f.style.width = '100%';
          } else { f.style.transition = 'none'; f.style.width = '0%'; }
        });
      }
      go(0);
      if (reduce) return; // hold on the first slide; no autoplay
      setInterval(function () { go((i + 1) % caps.length); }, dwell);
    })();

    // ---- Gallery: click-drag to scroll (native touch/trackpad already work) ----
    (function () {
      var rail = document.getElementById('hl-rail');
      if (!rail) return;
      var down = false, startX = 0, startScroll = 0, moved = false;
      rail.addEventListener('pointerdown', function (e) {
        if (e.pointerType === 'touch') return; // let native touch scroll handle it
        down = true; moved = false;
        startX = e.clientX; startScroll = rail.scrollLeft;
        rail.classList.add('dragging');
      });
      window.addEventListener('pointermove', function (e) {
        if (!down) return;
        var dx = e.clientX - startX;
        if (Math.abs(dx) > 3) moved = true;
        rail.scrollLeft = startScroll - dx;
      });
      window.addEventListener('pointerup', function () {
        down = false; rail.classList.remove('dragging');
      });
      // Suppress the click that follows a drag (so a drag doesn't feel like a tap).
      rail.addEventListener('click', function (e) { if (moved) { e.preventDefault(); } }, true);
    })();
  })();
</script>

