<script is:inline>
  // Apple-style scroll-scrub: map scroll progress through .scrub-track to a
  // frame of the real Today page (frame-000 … frame-026), all preloaded so the
  // swap is instant. Falls back to a single static frame if reduced motion.
  (function () {
    var TOTAL = 27;
    var img = document.getElementById('scrubImg');
    var track = document.querySelector('.scrub-track');
    if (!img || !track) return;

    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var frames = [];
    for (var i = 0; i < TOTAL; i++) {
      var n = ('00' + i).slice(-3);
      var url = '/scrub/frame-' + n + '.jpg';
      var im = new Image();
      im.src = url;
      frames.push(url);
    }
    if (reduce) { img.src = frames[Math.floor(TOTAL / 2)]; return; }

    var current = 0, ticking = false;
    function update() {
      ticking = false;
      var rect = track.getBoundingClientRect();
      var vh = window.innerHeight || document.documentElement.clientHeight;
      // progress: 0 when the track top hits the viewport top, 1 when its
      // bottom (minus one viewport) has scrolled past.
      var scrollable = rect.height - vh;
      var progress = scrollable > 0 ? (-rect.top) / scrollable : 0;
      progress = Math.max(0, Math.min(1, progress));
      var idx = Math.min(TOTAL - 1, Math.round(progress * (TOTAL - 1)));
      if (idx !== current) { current = idx; img.src = frames[idx]; }
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>

