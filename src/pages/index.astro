<script is:inline>
  (function () {
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var fmt = function (n) { return '$' + Math.round(n).toLocaleString('en-US'); };

    // ---- Scroll reveal ----
    var revs = document.querySelectorAll('.rev');
    if (reduce || !('IntersectionObserver' in window)) {
      revs.forEach(function (el) { el.classList.add('in'); });
    } else {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      revs.forEach(function (el) { io.observe(el); });
    }

    // ---- Hero savings counter (count-up, ease-out cubic ~1.6s) ----
    (function () {
      var el = document.getElementById('hero-counter');
      if (!el) return;
      var target = parseFloat(el.getAttribute('data-target')) || 0;
      if (reduce) { el.textContent = fmt(target); return; }
      var dur = 1600, t0 = null;
      var ease = function (x) { return 1 - Math.pow(1 - x, 3); };
      function tick(now) {
        if (t0 === null) t0 = now;
        var p = Math.min(1, (now - t0) / dur);
        el.textContent = fmt(target * ease(p));
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    })();

    // ---- Value calculator ----
    (function () {
      var rows = [].slice.call(document.querySelectorAll('#calc-list .tool-row'));
      var elMonthly = document.getElementById('calc-monthly');
      var elAnnual = document.getElementById('calc-annual');
      var elCount = document.getElementById('calc-count');
      if (!rows.length) return;

      function recompute() {
        var monthly = 0, count = 0;
        rows.forEach(function (r) {
          if (r.getAttribute('data-on') === '1') {
            monthly += parseFloat(r.getAttribute('data-cost')) || 0;
            count++;
          }
        });
        elMonthly.textContent = fmt(monthly);
        elAnnual.textContent = fmt(monthly * 12);
        elCount.textContent = count;
      }

      rows.forEach(function (r) {
        function toggle() {
          var on = r.getAttribute('data-on') !== '1';
          r.setAttribute('data-on', on ? '1' : '0');
          r.setAttribute('aria-checked', on ? 'true' : 'false');
          var box = r.querySelector('.tool-box');
          var amt = r.querySelector('.tool-amt');
          box.textContent = on ? '✓' : '';
          box.style.borderColor = on ? '#14B8A6' : '#CBD2D9';
          box.style.background = on ? '#14B8A6' : 'transparent';
          amt.style.color = on ? '#1B1A22' : '#C2C8D0';
          recompute();
        }
        r.setAttribute('role', 'checkbox');
        r.setAttribute('tabindex', '0');
        r.setAttribute('aria-checked', 'true');
        r.addEventListener('click', toggle);
        r.addEventListener('keydown', function (e) {
          if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); toggle(); }
        });
      });
      recompute();
    })();

    // ---- Integrations marquee (seamless loop) ----
    (function () {
      var track = document.getElementById('intg-track');
      if (!track || reduce) return;
      track.innerHTML += track.innerHTML; // duplicate for a seamless wrap
      var x = 0;
      function step() {
        x -= 0.5;
        var half = track.scrollWidth / 2;
        if (-x >= half) x = 0;
        track.style.transform = 'translateX(' + x + 'px)';
        requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    })();

    // ---- Lead form: background POST + inline thank-you (no redirect) ----
    (function () {
      var form = document.getElementById('demo-form');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        try {
          fetch(form.action || '/api/trial', { method: 'POST', body: new FormData(form) }).catch(function () {});
        } catch (_) {}
        var btn = document.getElementById('demo-submit');
        var thanks = document.getElementById('demo-thanks');
        if (btn) { btn.textContent = '✓ Request received'; btn.disabled = true; btn.style.opacity = '0.7'; btn.style.cursor = 'default'; }
        if (thanks) thanks.hidden = false;
        try { form.reset(); } catch (_) {}
      });
    })();
  })();
</script>

  </body>
</html>
