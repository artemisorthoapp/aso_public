    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/artemis-icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Karla:wght@300;400;500;600;700;800&family=Philosopher:wght@400;700&display=swap"
    />

    <style is:global>
      html { scroll-behavior:smooth; }
      body { margin:0; background:#fff; font-family:'Karla',system-ui,sans-serif; color:#24232D; -webkit-font-smoothing:antialiased; }
      @keyframes ao-float { 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-12px); } }
      @keyframes ao-mesh { 0%{ transform:translate(0,0) scale(1);} 50%{ transform:translate(4%,3%) scale(1.12);} 100%{ transform:translate(0,0) scale(1);} }
      @keyframes ao-mesh2 { 0%{ transform:translate(0,0) scale(1.1);} 50%{ transform:translate(-5%,-3%) scale(1);} 100%{ transform:translate(0,0) scale(1.1);} }
      @keyframes ao-pulse { 0%,100%{ opacity:.55;} 50%{ opacity:1;} }
      @keyframes ao-shimmer { 0%{ background-position:-200% 0;} 100%{ background-position:200% 0;} }
      @keyframes ao-blink { 0%,49%{ opacity:1;} 50%,100%{ opacity:0;} }
      @keyframes ao-rise { 0%{ transform:translateY(8px); opacity:0;} 100%{ transform:translateY(0); opacity:1;} }
      @keyframes ao-bar { 0%{ transform:scaleY(.2);} 100%{ transform:scaleY(1);} }

      /* ---- Scroll-scrub hero (real Today UI, frame sequence) ---- */
      .scrub-track { height: 230vh; margin-top: 48px; }
      .scrub-stage { position: sticky; top: 0; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px; }
      .scrub-frame { width: min(980px, 92vw); background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; padding: 8px; box-shadow: 0 40px 90px rgba(0,0,0,0.5); }
      .scrub-viewport { border-radius: 10px; overflow: hidden; background: #FBFBFC; aspect-ratio: 1440 / 900; }
      .scrub-viewport img { display: block; width: 100%; height: 100%; object-fit: cover; object-position: top center; }
      .scrub-hint { font-size: 13px; font-weight: 700; letter-spacing: .04em; color: rgba(255,255,255,0.5); text-transform: uppercase; }
      @media (max-width: 900px) { .scrub-track { height: 180vh; } }
      @media (prefers-reduced-motion: reduce) { .scrub-track { height: auto; } .scrub-stage { position: static; height: auto; padding: 8px 0 0; } }

      /* ---- Product gallery: real screenshot cards ---- */
      .shot-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; overflow: hidden; transition: transform .4s cubic-bezier(0.16,1,0.3,1), border-color .4s; }
      .shot-card:hover { transform: translateY(-4px); border-color: rgba(105,201,204,0.4); }
      .shot-view { aspect-ratio: 16 / 10; overflow: hidden; background: #1F2230; border-bottom: 1px solid rgba(255,255,255,0.08); }
      .shot-view img { display: block; width: 100%; height: 100%; object-fit: cover; object-position: top center; }

      /* ---- Responsive: collapse the fixed grids for tablet / phone ---- */
      img { max-width: 100%; }
      /* Tablet & below (incl. iPad portrait 768) */
      @media (max-width: 900px) {
        .feat-row { grid-template-columns: 1fr !important; gap: 36px !important; }
        .feat-row > * { order: 0 !important; }   /* text leads, visual follows */
        .gallery-grid { grid-template-columns: repeat(2, 1fr) !important; }
      }
      /* Phone */
      @media (max-width: 600px) {
        .nav-links a:not(.nav-cta) { display: none !important; }
        .gallery-grid { grid-template-columns: 1fr !important; }
        .results-stats { grid-template-columns: 1fr !important; gap: 28px !important; }
        .form-names { grid-template-columns: 1fr !important; }
        .mock-grid { grid-template-columns: 1fr !important; }
        .mock-sidebar { display: none !important; }
        .footer-links { flex-wrap: wrap !important; gap: 14px 18px !important; }
        .sec-pad { padding-top: 76px !important; padding-bottom: 76px !important; }
      }
    </style>
    <noscript><style>[data-reveal]{opacity:1 !important; transform:none !important;}</style></noscript>
  </head>
