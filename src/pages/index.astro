---
// Landing page — ported from the "Artemis Ortho website redesign" Claude Design
// doc ("Artemis Ortho Website.dc.html"). Self-contained single-page design with
// its own fixed nav + footer, so it intentionally does NOT use Base/Nav/Footer.
// The Claude-Design runtime (<x-dc>, support.js, _ds stylesheet, DCLogic) has
// been stripped; the signup form posts to the real /api/trial Pages Function and
// scroll-reveal runs as a plain client script.
const title = "Artemis Ortho App — your whole practice, briefed by morning";
const description =
  "Artemis reads your Cloud 9 data overnight — verifies insurance, reconciles the day, and hands your team the three things that actually need them. A briefing, not a dashboard.";
const canonical = new URL("/", Astro.site).href;
---

