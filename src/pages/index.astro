<section style="background:#16161C; color:#fff;">
  <div class="scrub-track" style="position:relative; z-index:1;">
    <div class="scrub-stage">
      <div class="scrub-frame">
        <!-- browser chrome -->
        <div style="display:flex; align-items:center; gap:8px; padding:11px 16px; border-bottom:1px solid rgba(0,0,0,0.06); background:#fff;">
