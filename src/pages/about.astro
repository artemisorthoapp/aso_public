---
import Base from "../layouts/Base.astro";

const values = [
  { title: "Calm over clutter", body: "Software should reduce the number of things a team has to hold in their head — not add another tab to check." },
  { title: "Honest numbers", body: "We show production, AR, and no-shows the way they really are, on the timeframes that matter — never vanity metrics." },
  { title: "Patients first", body: "Every minute the dashboard saves is a minute the team gives back to the chair." },
];
---

<Base title="About — Artemis">
  <section class="container-page py-16 sm:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">About</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        Built by an orthodontic practice, for orthodontic practices.
      </h1>
      <p class="mt-6 text-lg text-ink-soft">
        Artemis started inside a growing practice that was drowning in reports —
        production exports, funnel spreadsheets, AR aging PDFs — none of which
        agreed with each other. So we built one screen that does.
      </p>
    </div>
  </section>

  <section class="border-y border-brand-100 bg-brand-50/40">
    <div class="container-page grid gap-6 py-16 sm:grid-cols-3">
      {values.map((v) => (
        <div class="rounded-2xl border border-brand-100 bg-white p-7">
          <h2 class="font-display text-lg font-semibold text-ink">{v.title}</h2>
          <p class="mt-2 text-sm text-ink-soft">{v.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page py-16 text-center">
    <h2 class="font-display text-3xl font-bold text-ink">Want the backstory in person?</h2>
    <p class="mx-auto mt-3 max-w-xl text-ink-soft">
      We're happy to walk you through how Artemis works and whether it fits your practice.
    </p>
    <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/signup" class="btn-primary px-6 py-3 text-base">Start free trial</a>
      <a href="mailto:hello@artemisorthoapp.com" class="btn-outline px-6 py-3 text-base">Email us</a>
    </div>
  </section>
</Base>
