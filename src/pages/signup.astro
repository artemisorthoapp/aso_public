---
import Base from "../layouts/Base.astro";

// Preselect the plan when arriving from a pricing card (/signup?plan=growth).
const plan = (Astro.url.searchParams.get("plan") || "growth").toLowerCase();
const plans = ["starter", "growth", "enterprise"];
const selected = plans.includes(plan) ? plan : "growth";

// Posts to the Cloudflare Pages Function (functions/api/trial.js), which
// captures the lead (optional webhook forward) and continues the visitor to the
// dashboard app to finish account creation.
const formAction = "/api/trial";
---

<Base title="Start your free trial — Artemis">
  <section class="container-page grid gap-12 py-16 sm:py-20 lg:grid-cols-2">
    <div>
      <p class="eyebrow">Get started</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        Start your free trial.
      </h1>
      <p class="mt-5 text-lg text-ink-soft">
        Tell us a little about your practice and we'll get you set up. No credit
        card required.
      </p>
      <ul class="mt-8 space-y-4">
        {[
          ["1", "Create your account", "Takes a minute — you're the admin."],
          ["2", "Connect your practice data", "We guide you through the integration."],
          ["3", "See your funnel come alive", "Today, People, Money — populated on your numbers."],
        ].map(([n, t, b]) => (
          <li class="flex gap-4">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-500 font-semibold text-white">{n}</span>
            <div>
              <p class="font-medium text-ink">{t}</p>
              <p class="text-sm text-ink-soft">{b}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="rounded-2xl border border-brand-100 bg-white p-7 shadow-sm sm:p-9">
      <form action={formAction} method="post" class="space-y-5">
        <!-- Honeypot: hidden from users, catches bots. Must stay empty. -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label>Company website<input type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-ink">First name</span>
            <input name="first_name" type="text" required autocomplete="given-name"
              class="mt-1 w-full rounded-xl border border-brand-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-ink">Last name</span>
            <input name="last_name" type="text" required autocomplete="family-name"
              class="mt-1 w-full rounded-xl border border-brand-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30" />
          </label>
        </div>
        <label class="block">
          <span class="text-sm font-medium text-ink">Practice name</span>
          <input name="practice" type="text" required
            class="mt-1 w-full rounded-xl border border-brand-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink">Work email</span>
          <input name="email" type="email" required autocomplete="email"
            class="mt-1 w-full rounded-xl border border-brand-200 px-3 py-2.5 text-sm focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink">Plan</span>
          <select name="plan"
            class="mt-1 w-full rounded-xl border border-brand-200 bg-white px-3 py-2.5 text-sm capitalize focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/30">
            {plans.map((p) => (
              <option value={p} selected={p === selected}>{p}</option>
            ))}
          </select>
        </label>
        <button type="submit" class="btn-primary w-full px-6 py-3 text-base">Create account</button>
        <p class="text-center text-xs text-ink-soft">
          By continuing you agree to our
          <a href="https://app.artemisorthoapp.com/terms-of-service" class="text-brand-700 hover:underline">Terms of Service</a>
          and
          <a href="https://app.artemisorthoapp.com/privacy-policy" class="text-brand-700 hover:underline">Privacy Policy</a>.
          Already have an account?
          <a href="https://artemissmiles.artemisorthoapp.com" class="text-brand-700 hover:underline">Sign in</a>.
        </p>
      </form>
    </div>
  </section>
</Base>
