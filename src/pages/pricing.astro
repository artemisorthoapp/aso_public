---
import Base from "../layouts/Base.astro";

const tiers = [
  {
    name: "Starter",
    price: "$299",
    cadence: "/mo per office",
    blurb: "Everything a single-location practice needs to run the day.",
    features: [
      "Today briefing + treatment funnel",
      "Production & AR dashboards",
      "Chair utilization & scheduling",
      "Up to 10 staff seats",
    ],
    cta: "Start free trial",
    href: "/signup?plan=starter",
    featured: false,
  },
  {
    name: "Growth",
    price: "$549",
    cadence: "/mo per office",
    blurb: "For practices investing in marketing and patient growth.",
    features: [
      "Everything in Starter",
      "Growth scoreboard + lead tracking",
      "Review campaigns & local SEO",
      "Artemis AI assistant",
      "Unlimited staff seats",
    ],
    cta: "Start free trial",
    href: "/signup?plan=growth",
    featured: true,
  },
  {
    name: "Enterprise",
    price: "Custom",
    cadence: "",
    blurb: "Multi-location groups and DSOs with advanced needs.",
    features: [
      "Everything in Growth",
      "Multi-location rollups",
      "Dedicated database tier",
      "SSO & advanced permissions",
      "Priority onboarding & support",
    ],
    cta: "Talk to us",
    href: "mailto:sales@artemisorthoapp.com",
    featured: false,
  },
];

const faqs = [
  { q: "Is there a free trial?", a: "Yes — every plan starts with a no-credit-card trial. Connect your data and explore the full product." },
  { q: "Which practice systems do you support?", a: "Artemis is built to ingest from common orthodontic practice-management systems. Tell us yours during signup and we'll confirm fit." },
  { q: "Can I change plans later?", a: "Anytime. Upgrade as you add locations or marketing; downgrade just as easily." },
  { q: "Is my patient data secure?", a: "We treat PHI as a first-class concern — encryption in transit and at rest, least-privilege access, and audit logging throughout." },
];
---

<Base title="Pricing — Artemis">
  <section class="container-page py-16 text-center sm:py-20">
    <p class="eyebrow">Pricing</p>
    <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
      Simple plans, no surprises.
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-ink-soft">
      Start on a single office and scale to a group. Every plan includes the core
      dashboard and free updates.
    </p>
  </section>

  <section class="container-page pb-16">
    <div class="grid gap-6 lg:grid-cols-3">
      {tiers.map((t) => (
        <div
          class:list={[
            "flex flex-col rounded-2xl border bg-white p-8 shadow-sm",
            t.featured ? "border-brand-500 ring-2 ring-brand-500/30" : "border-brand-100",
          ]}
        >
          {t.featured && (
            <span class="mb-3 self-start rounded-full bg-brand-500 px-3 py-1 text-xs font-semibold text-white">
              Most popular
            </span>
          )}
          <h2 class="font-display text-xl font-semibold text-ink">{t.name}</h2>
          <p class="mt-1 text-sm text-ink-soft">{t.blurb}</p>
          <p class="mt-5">
            <span class="font-display text-4xl font-bold text-ink">{t.price}</span>
            <span class="text-sm text-ink-soft">{t.cadence}</span>
          </p>
          <ul class="mt-6 flex-1 space-y-2.5">
            {t.features.map((f) => (
              <li class="flex items-start gap-2 text-sm text-ink">
                <span class="mt-1 grid h-4 w-4 shrink-0 place-items-center rounded-full bg-brand-100 text-brand-700">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <a
            href={t.href}
            class:list={["mt-8 px-6 py-3 text-base", t.featured ? "btn-primary" : "btn-outline"]}
          >
            {t.cta}
          </a>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page pb-20">
    <h2 class="text-center font-display text-3xl font-bold text-ink">Frequently asked</h2>
    <div class="mx-auto mt-8 max-w-3xl divide-y divide-brand-100 rounded-2xl border border-brand-100 bg-white">
      {faqs.map((f) => (
        <details class="group p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-ink">
            {f.q}
            <span class="text-brand-500 transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 text-ink-soft">{f.a}</p>
        </details>
      ))}
    </div>
  </section>
</Base>
