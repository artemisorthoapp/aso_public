---
const year = new Date().getFullYear();
const cols = [
  {
    title: "Product",
    links: [
      { href: "/features", label: "Features" },
      { href: "/pricing", label: "Pricing" },
      { href: "/signup", label: "Get started" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/about", label: "About" },
      { href: "mailto:hello@artemisorthoapp.com", label: "Contact" },
    ],
  },
  {
    // Canonical legal docs live in the product app (single source of truth);
    // OAuth app reviewers (Google/Meta/TikTok) follow these from the homepage.
    title: "Legal",
    links: [
      { href: "https://app.artemisorthoapp.com/privacy-policy", label: "Privacy Policy" },
      { href: "https://app.artemisorthoapp.com/terms-of-service", label: "Terms of Service" },
    ],
  },
];
---

<footer class="border-t border-brand-100 bg-brand-50/40">
  <div class="container-page grid gap-10 py-12 sm:grid-cols-2 lg:grid-cols-5">
    <div class="space-y-3">
      <a href="/" class="flex items-center gap-2 font-display text-lg font-bold text-ink">
        <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-500 text-white">A</span>
        Artemis
      </a>
      <p class="max-w-xs text-sm text-ink-soft">
        The operating system for the modern orthodontic practice.
      </p>
    </div>

    {cols.map((col) => (
      <div>
        <h2 class="text-sm font-semibold text-ink">{col.title}</h2>
        <ul class="mt-3 space-y-2">
          {col.links.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-ink-soft hover:text-brand-700">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div>
      <h2 class="text-sm font-semibold text-ink">Get started</h2>
      <p class="mt-3 text-sm text-ink-soft">Ready to see it on your data?</p>
      <a href="/signup" class="btn-primary mt-3">Start free trial</a>
    </div>
  </div>

  <div class="container-page flex flex-col items-center justify-between gap-2 border-t border-brand-100 py-6 text-xs text-ink-soft sm:flex-row">
    <p>© {year} Artemis Ortho App LLC. All rights reserved.</p>
    <p>Built for orthodontic teams.</p>
  </div>
</footer>
