---
// A faithful, representative mock of the Artemis "Today" view — the dashboard's
// home (DESIGN_CONSTITUTION §14): charcoal sidebar of the 5 verbs, a greeting,
// the Artemis ⌘K spine, numbered briefing cards (sentence headlines with real
// numbers, §16 tone), and a 4-tile quiet rail of ortho-real KPIs (§22).
// Not a screenshot — built to mirror the real UI so the marketing site stays
// crisp and responsive. Swap for live screenshots once the app is captured.

const nav = [
  { label: "Today", active: true, icon: "M12 3v2m0 14v2m9-9h-2M5 12H3m14.5-6.5l-1.4 1.4M7.9 16.1l-1.4 1.4m0-11.4l1.4 1.4m8.2 8.2l1.4 1.4" },
  { label: "People", active: false, icon: "M16 19a4 4 0 00-8 0M12 11a3 3 0 100-6 3 3 0 000 6z" },
  { label: "Growth", active: false, icon: "M4 19V5m0 14h16M8 15l3-4 3 2 4-6" },
  { label: "Money", active: false, icon: "M12 3v18m4-14H10a2 2 0 000 4h4a2 2 0 010 4H8" },
  { label: "Operations", active: false, icon: "M4 6h16M4 12h16M4 18h16" },
];

const briefings = [
  {
    n: "01",
    tone: "danger",
    eyebrow: "Treatment Coordinator",
    headline: "8 contracts have sat unsigned for more than 7 days — $94k of pipeline at risk.",
    action: "Review contracts",
  },
  {
    n: "02",
    tone: "warn",
    eyebrow: "Growth",
    headline: "Yelp cost-per-start jumped to $840 this week — 2× your target.",
    action: "See Growth",
  },
  {
    n: "03",
    tone: "good",
    eyebrow: "Doctor",
    headline: "Same-day start rate hit 71% this month, up from 58%.",
    action: "View funnel",
  },
];

const rail = [
  { label: "Production · MTD", value: "$312k", sub: "88% of target" },
  { label: "AR > 60 days", value: "$48k", sub: "down $6k" },
  { label: "Chair utilization", value: "82%", sub: "rolling 4 wks" },
  { label: "No-show rate · 30d", value: "6.2%", sub: "−1.1 pts" },
];

const toneBar = {
  good: "bg-brand-500",
  warn: "bg-amber-400",
  danger: "bg-rose-500",
};
---

<div class="overflow-hidden rounded-2xl border border-brand-100 bg-white shadow-xl shadow-brand-900/5 ring-1 ring-black/5">
  <!-- faux window chrome -->
  <div class="flex items-center gap-1.5 border-b border-brand-100 bg-brand-50/60 px-4 py-2.5">
    <span class="h-2.5 w-2.5 rounded-full bg-rose-300"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-amber-300"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-brand-300"></span>
    <span class="ml-3 text-xs text-ink-soft">artemissmiles.artemisorthoapp.com/today</span>
  </div>

  <div class="grid grid-cols-[64px_1fr] sm:grid-cols-[180px_1fr]">
    <!-- charcoal sidebar -->
    <aside class="bg-ink p-3 text-white/80 sm:p-4">
      <div class="mb-5 flex items-center gap-2">
        <span class="grid h-7 w-7 place-items-center rounded-lg bg-brand-500 text-sm font-bold text-white">A</span>
        <span class="hidden font-display text-sm font-semibold text-white sm:inline">Artemis</span>
      </div>
      <nav class="space-y-1">
        {nav.map((item) => (
          <div
            class:list={[
              "flex items-center gap-2.5 rounded-lg px-2.5 py-2 text-xs font-medium",
              item.active ? "bg-white/10 text-white" : "text-white/60",
            ]}
          >
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d={item.icon} /></svg>
            <span class="hidden sm:inline">{item.label}</span>
          </div>
        ))}
      </nav>
    </aside>

    <!-- cloud main -->
    <div class="bg-[#FBF9F6] p-4 sm:p-6">
      <p class="text-sm font-semibold text-ink">Good morning, Dr. Bennie.</p>
      <p class="text-xs text-ink-soft">Three things need you today.</p>

      <!-- Artemis ⌘K spine -->
      <div class="mt-3 flex items-center gap-2 rounded-xl border border-brand-200 bg-white px-3 py-2.5">
        <span class="grid h-5 w-5 place-items-center rounded-md bg-gradient-to-br from-brand-500 to-accent text-[10px] font-bold text-white">A</span>
        <span class="text-xs text-ink-soft">Ask Artemis anything…</span>
        <kbd class="ml-auto rounded border border-brand-200 px-1.5 py-0.5 text-[10px] text-ink-soft">⌘K</kbd>
      </div>

      <!-- briefing cards -->
      <div class="mt-4 space-y-2.5">
        {briefings.map((b) => (
          <div class="flex gap-3 overflow-hidden rounded-xl border border-brand-100 bg-white p-3">
            <span class:list={["w-1 shrink-0 rounded-full", toneBar[b.tone]]}></span>
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-display text-xs font-bold text-ink-soft">{b.n}</span>
                <span class="text-[10px] font-semibold uppercase tracking-wide text-brand-600">{b.eyebrow}</span>
              </div>
              <p class="mt-0.5 text-xs leading-snug text-ink">{b.headline}</p>
              <button class="mt-1.5 text-[11px] font-semibold text-brand-600">{b.action} →</button>
            </div>
          </div>
        ))}
      </div>

      <!-- quiet rail -->
      <div class="mt-4 grid grid-cols-2 gap-2.5 lg:grid-cols-4">
        {rail.map((k) => (
          <div class="rounded-xl border border-brand-100 bg-white p-3">
            <p class="text-[10px] text-ink-soft">{k.label}</p>
            <p class="font-display text-lg font-bold tabular-nums text-ink">{k.value}</p>
            <p class="text-[10px] text-brand-600">{k.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
