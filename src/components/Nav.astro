---
const links = [
  { href: "/features", label: "Features" },
  { href: "/pricing", label: "Pricing" },
  { href: "/about", label: "About" },
];
const { pathname } = Astro.url;
// App sign-in lives in the dashboard product, not this marketing site.
const appUrl = "https://artemissmiles.artemisorthoapp.com";
---

<header class="sticky top-0 z-40 border-b border-brand-100/70 bg-white/80 backdrop-blur">
  <nav class="container-page flex h-16 items-center justify-between" aria-label="Primary">
    <a href="/" class="flex items-center gap-2 font-display text-lg font-bold text-ink">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-500 text-white">A</span>
      Artemis
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-brand-50",
            pathname === l.href ? "text-brand-700" : "text-ink-soft",
          ]}
          aria-current={pathname === l.href ? "page" : undefined}
        >
          {l.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <a href={appUrl} class="hidden btn-ghost sm:inline-flex">Sign in</a>
      <a href="/signup" class="btn-primary">Get started</a>
    </div>
  </nav>
</header>
